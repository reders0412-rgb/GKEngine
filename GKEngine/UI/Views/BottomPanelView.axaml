<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GKEngine.UI.ViewModels"
             xmlns:views="clr-namespace:GKEngine.UI.Views"
             x:Class="GKEngine.UI.Views.BottomPanelView"
             x:DataType="vm:EditorViewModel"
             Background="{DynamicResource BrushBgDeep}">

    <Grid ColumnDefinitions="*,3,*">

        <!-- ══ PROJECT PANEL ══════════════════════════════ -->
        <views:DetachablePanelView Grid.Column="0"
                                   Title="{Binding ProjectLabel}">
            <views:DetachablePanelView.PanelBody>
                <DockPanel>

                    <!-- Breadcrumb + path -->
                    <Border DockPanel.Dock="Top"
                            Padding="8,4"
                            Background="{DynamicResource BrushBgDeep}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Button DockPanel.Dock="Left"
                                    Content="◀" Classes="IconBtn" Padding="4,2" FontSize="11"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding AssetBreadcrumb}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AssetItem">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text=" ▸ " FontSize="11"
                                                           Foreground="{DynamicResource BrushTextLo}"/>
                                                <TextBlock Text="{Binding Name}" FontSize="11"
                                                           Foreground="{DynamicResource BrushAccent}"
                                                           Cursor="Hand"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Asset grid — supports drag & drop from Explorer -->
                    <ScrollViewer x:Name="AssetDropTarget"
                                  AllowDrop="True"
                                  DragDrop.Drop="OnAssetDrop"
                                  DragDrop.DragOver="OnAssetDragOver">
                        <WrapPanel Margin="6" ItemWidth="80">
                            <ItemsControl ItemsSource="{Binding AssetItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AssetItem">
                                        <Border Width="76" Margin="2"
                                                CornerRadius="4"
                                                Background="{DynamicResource BrushBgCard}"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource BrushBorder}"
                                                Padding="4"
                                                Cursor="Hand"
                                                ToolTip.Tip="{Binding FullPath}">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Icon}"
                                                           FontSize="24"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource BrushTextHi}"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           MaxLines="2"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>
                    </ScrollViewer>

                </DockPanel>
            </views:DetachablePanelView.PanelBody>
        </views:DetachablePanelView>

        <GridSplitter Grid.Column="1"
                      ResizeDirection="Columns"
                      Background="{DynamicResource BrushBorder}"/>

        <!-- ══ CONSOLE PANEL ══════════════════════════════ -->
        <views:DetachablePanelView Grid.Column="2"
                                   Title="{Binding ConsoleLabel}">
            <views:DetachablePanelView.PanelBody>
                <DockPanel>

                    <!-- Console toolbar -->
                    <Border DockPanel.Dock="Top"
                            Padding="6,4"
                            Background="{DynamicResource BrushBgDeep}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="0,0,0,1">
                        <DockPanel>

                            <!-- Clear button -->
                            <Button DockPanel.Dock="Left"
                                    Content="Clear"
                                    Classes="Secondary"
                                    FontSize="11"
                                    Padding="8,3"
                                    Command="{Binding ClearConsoleCommand}"/>

                            <!-- Filter toggles -->
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal" Spacing="4">
                                <ToggleButton IsChecked="{Binding ShowInfo}"
                                             Content="ℹ Info"
                                             FontSize="11" Padding="6,2"/>
                                <ToggleButton IsChecked="{Binding ShowWarning}"
                                             Content="⚠ Warn"
                                             FontSize="11" Padding="6,2"/>
                                <ToggleButton IsChecked="{Binding ShowError}"
                                             Content="✖ Error"
                                             FontSize="11" Padding="6,2"/>
                            </StackPanel>

                            <!-- Search -->
                            <TextBox Text="{Binding ConsoleSearch}"
                                     Watermark="Filter..."
                                     FontSize="11"
                                     Margin="6,0"
                                     Background="#0F0F14"
                                     Foreground="{DynamicResource BrushTextHi}"
                                     BorderBrush="{DynamicResource BrushBorder}"
                                     CornerRadius="4"
                                     Padding="6,2"/>
                        </DockPanel>
                    </Border>

                    <!-- Log entries -->
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding FilteredConsole}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ConsoleEntry">
                                    <Border Padding="8,4"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="16,60,*,80">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Icon}"
                                                       FontSize="11"
                                                       Foreground="{Binding Color}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Time}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource BrushTextLo}"
                                                       FontFamily="Cascadia Mono, Consolas"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Message}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource BrushTextHi}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Source}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource BrushTextLo}"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </DockPanel>
            </views:DetachablePanelView.PanelBody>
        </views:DetachablePanelView>

    </Grid>

</UserControl>
